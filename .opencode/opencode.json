{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "instructions": [
    "~/AGENTS.md"
  ],
  "permission": {
    "bd *": "allow",
    "websearch": "allow",
    "external_directory": {
      "/tmp/**": "allow"
    }
  },
  "plugin": ["opencode-beads", "@ex-machina/opencode-anthropic-auth"],
  "provider": {
    "anthropic": {
      "models": {
        "claude-opus-4-6-1m": {
          "id": "claude-opus-4-6",
          "name": "Claude Opus 4.6 (1M)",
          "limit": {
            "context": 1000000,
            "output": 65536
          }
        }
      }
    }
  },
  "agent": {
    "plan": {
      "permission": {
        "external_directory": {
          "~/projects/**": "allow"
        }
      }
    }
  }
}
