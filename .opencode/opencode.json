{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "instructions": ["~/AGENTS.md"],
  "permission": {
    "bd *": "allow",
    "websearch": "allow",
    "external_directory": {
      "/tmp/**": "allow"
    }
  },
  "plugin": ["opencode-beads", "@ex-machina/opencode-anthropic-auth"],
  "agent": {
    "plan": {
      "permission": {
        "external_directory": {
          "~/projects/**": "allow"
        }
      }
    }
  }
}
